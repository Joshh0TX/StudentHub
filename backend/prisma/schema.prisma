generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  profilePic String?
  bio        String?
  department String
  level      Int
  createdAt  DateTime @default(now())
  createdCourses Course[] @relation("UserCreatedCourses")

  // Academic
  courseMemberships CourseMember[]
  coursesCreated    Course[]

  // Social
  posts     Post[]
  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  // Existing features
  resources     Resource[]
  pastQuestions PastQuestion[]
  quizzes       Quiz[]
  studyGroups   StudyGroup[]
  GroupMember   StudyGroupMember[]

  // Marketplace
  store Store?
}

model Course {
  id         String   @id @default(uuid())
  name       String
  courseCode String
  classCode  String   @unique
  createdBy  String
  createdAt  DateTime @default(now())

  creator     User             @relation("UserCreatedCourses", fields: [createdBy], references: [id])
  members     CourseMember[]
  assignments Assignment[]
  timetable   TimetableEntry[]
}

model CourseMember {
  id       String @id @default(uuid())
  userId   String
  courseId String
  role     String @default("student")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  courseId    String
  createdBy   String
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
}

model TimetableEntry {
  id        String  @id @default(uuid())
  courseId  String
  day       String
  startTime String
  endTime   String
  location  String?

  course Course @relation(fields: [courseId], references: [id])
}

model Post {
  id        String   @id @default(uuid())
  content   String
  image     String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String

  follower  User @relation("followers", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model StudyGroup {
  id           String   @id @default(cuid())
  name         String
  course_code  String
  course_title String
  description  String?
  max_members  Int
  department   String
  year         Int?
  createdBy    String
  createdAt    DateTime @default(now())

  creator   User               @relation(fields: [createdBy], references: [id])
  resources Resource[]
  members   StudyGroupMember[]
}

model StudyGroupMember {
  id       String     @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime   @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id])
  user  User       @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  type        String
  url         String
  description String?
  department  String
  courseCode  String
  courseTitle String?
  year        Int?
  groupId     String?
  uploadedBy  String
  createdAt   DateTime @default(now())

  group    StudyGroup? @relation(fields: [groupId], references: [id])
  uploader User        @relation(fields: [uploadedBy], references: [id])
}

model PastQuestion {
  id         String   @id @default(uuid())
  courseCode String
  year       Int
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploadedBy], references: [id])
}

model Quiz {
  id         String     @id @default(uuid())
  title      String
  courseCode String
  createdBy  String
  createdAt  DateTime   @default(now())

  creator   User       @relation(fields: [createdBy], references: [id])
  questions Question[]
}

model Question {
  id            String @id @default(uuid())
  quizId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model Store {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("goods")
  ownerId     String   @unique
  createdAt   DateTime @default(now())

  owner    User           @relation(fields: [ownerId], references: [id])
  products Product[]
  contacts StoreContact[]
}

model StoreContact {
  id      String @id @default(uuid())
  storeId String
  type    String
  value   String

  store Store @relation(fields: [storeId], references: [id])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  type        String   @default("goods")
  category    String
  locations   String[]
  storeId     String
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])
}
