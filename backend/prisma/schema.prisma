generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  profilePic String?
  bio        String?
  department String
  level      Int
  createdAt  DateTime @default(now())

  // Academic
  courseMemberships CourseMember[]

  // Social
  posts     Post[]
  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  // Existing features
  resources     Resource[]
  pastQuestions PastQuestion[]
  quizzes       Quiz[]
}

model Course {
  id         String   @id @default(uuid())
  name       String
  courseCode String
  classCode  String   @unique
  createdBy  String
  createdAt  DateTime @default(now())

  creator     User           @relation(fields: [createdBy], references: [id])
  members     CourseMember[]
  assignments Assignment[]
  timetable   TimetableEntry[]
}

model CourseMember {
  id       String @id @default(uuid())
  userId   String
  courseId String
  role     String @default("student") // "rep" | "student"

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  courseId    String
  createdBy   String
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
}

model TimetableEntry {
  id        String @id @default(uuid())
  courseId  String
  day       String
  startTime String
  endTime   String
  location  String?

  course Course @relation(fields: [courseId], references: [id])
}

model Post {
  id        String   @id @default(uuid())
  content   String
  image     String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String

  follower  User @relation("followers", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Resource {
  id         String   @id @default(uuid())
  title      String
  type       String
  url        String
  courseCode String
  uploadedBy String
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploadedBy], references: [id])
}

model PastQuestion {
  id         String   @id @default(uuid())
  courseCode String
  year       Int
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploadedBy], references: [id])
}

model Quiz {
  id         String     @id @default(uuid())
  title      String
  courseCode String
  createdBy  String
  createdAt  DateTime   @default(now())

  creator   User       @relation(fields: [createdBy], references: [id])
  questions Question[]
}

model Question {
  id            String @id @default(uuid())
  quizId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String

  quiz Quiz @relation(fields: [quizId], references: [id])
}