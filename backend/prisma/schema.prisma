generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  department String
  level      Int
  createdAt  DateTime @default(now())

  groupMemberships GroupMember[]
  resources        Resource[]
  pastQuestions    PastQuestion[]
  createdGroups    StudyGroup[]   @relation("GroupCreator")
  quizzes          Quiz[]
}

model StudyGroup {
  id          String   @id @default(uuid())
  name        String
  department  String
  level       Int
  description String?
  createdBy   String
  creator     User     @relation("GroupCreator", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())

  members   GroupMember[]
  resources Resource[]
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String
  userId  String
  role    String @default("member")  // "admin" | "member"

  group StudyGroup @relation(fields: [groupId], references: [id])
  user  User       @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Resource {
  id         String   @id @default(uuid())
  title      String
  type       String   // "pdf" | "link" | "video"
  url        String
  department String
  courseCode String
  groupId    String?
  uploadedBy String
  createdAt  DateTime @default(now())

  group    StudyGroup? @relation(fields: [groupId], references: [id])
  uploader User        @relation(fields: [uploadedBy], references: [id])
}

model PastQuestion {
  id         String   @id @default(uuid())
  courseCode String
  year       Int
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploadedBy], references: [id])
}

model Timetable {
  id         String           @id @default(uuid())
  department String
  level      Int
  semester   String
  entries    TimetableEntry[]
}

model TimetableEntry {
  id          String    @id @default(uuid())
  timetableId String
  courseCode  String
  date        DateTime
  startTime   String
  endTime     String

  timetable Timetable @relation(fields: [timetableId], references: [id])
}

model Quiz {
  id         String     @id @default(uuid())
  title      String
  courseCode String
  createdBy  String
  createdAt  DateTime   @default(now())

  creator   User       @relation(fields: [createdBy], references: [id])
  questions Question[]
}

model Question {
  id            String @id @default(uuid())
  quizId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String

  quiz Quiz @relation(fields: [quizId], references: [id])
}